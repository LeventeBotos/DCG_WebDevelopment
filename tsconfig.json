{
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "target": "ES6",
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./*"
      ],
      "three/examples/jsm/*": [
        "./node_modules/@types/three/examples/jsm/*"
      ]
    }
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    ".next-workspace/types/**/*.ts",
    ".next-workspace/dev/types/**/*.ts",
    ".next-local/types/**/*.ts",
    ".next-local/dev/types/**/*.ts",
    "build/prod/types/**/*.ts",
    "build/prod/dev/types/**/*.ts",
    ".next-runtime/types/**/*.ts",
    ".next-runtime/dev/types/**/*.ts",
    ".next-deploy/types/**/*.ts",
    ".next-deploy/dev/types/**/*.ts",
    ".next-artifacts/types/**/*.ts",
    ".next-artifacts/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "build"
  ]
}
